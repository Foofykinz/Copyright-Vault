{
  "manifest_version": 3,
  "name": "Viral DRM Collector",
  "version": "0.1.0",
  "description": "Collects original client videos from TikTok and X and sends them to Viral DRM for tracking.",
  "action": {
    "default_title": "Viral DRM Collector"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "permissions": ["storage", "activeTab", "sidePanel"],
  "optional_host_permissions": ["https://*/*", "http://*/*"],
  "content_scripts": [
    {
      "matches": ["https://www.tiktok.com/@*"],
      "js": ["content-tiktok-network.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://www.tiktok.com/@*"],
      "js": ["content-tiktok.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content-x.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.facebook.com/*"],
      "js": ["content-facebook-network.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://www.facebook.com/*"],
      "js": ["content-facebook.js"],
      "run_at": "document_start"
    }
  ]
}
