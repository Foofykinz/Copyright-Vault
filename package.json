{
  "name": "viral-drm",
  "version": "1.0.0",
  "description": "Internal video organization tool for tracking client videos and grouping them into Combination Folders for Squeeze processing.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "npm run build && wrangler dev",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "deploy": "npm run build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply viral-drm-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply viral-drm-db --remote",
    "db:create": "wrangler d1 create viral-drm-db"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260715.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "wrangler": "^4.111.0"
  }
}
